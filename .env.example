# ========== Database (Supabase PostgreSQL) ==========
# Supabase 대시보드 > Settings > Database > URI 형식 복사 후 비밀번호 입력
# psycopg3 드라이버: postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://postgres:[password]@db.your-project.supabase.co:5432/postgres?sslmode=require

# ========== 환경 설정 ==========
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=True

# ========== JWT 설정 ==========
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== Supabase ==========
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ========== Email / Resend ==========
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@dreamlounge.dev

# ========== Frontend ==========
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# ========== Email Verification ==========
EMAIL_VERIFICATION_EXPIRY_MINUTES=1440
